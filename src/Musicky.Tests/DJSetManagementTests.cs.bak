using Microsoft.Playwright;
using Musicky.Tests.Fixtures;
using Musicky.Tests.Helpers;

namespace Musicky.Tests;

public class DJSetManagementTests : TestBase
{
    [Fact]
    public async Task DJSets_Page_Should_Be_Accessible()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);

        // Act
        await helpers.NavigateToDJSets();

        // Assert
        await Expect(page.GetByText("DJ Set Management")).ToBeVisibleAsync();
        await Expect(page.GetByText("Create a new DJ set")).ToBeVisibleAsync();
    }

    [Fact]
    public async Task DJSets_Link_Should_Appear_In_Navigation()
    {
        // Arrange
        using var page = await CreatePageAsync();

        // Act
        await page.GotoAsync("/");

        // Assert
        await Expect(page.GetByRole(AriaRole.Link, new() { Name = "DJ Sets" })).ToBeVisibleAsync();
    }

    [Fact]
    public async Task User_Can_Create_New_DJ_Set_With_Name_Only()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        var testSet = TestSets.All[0];
        
        await helpers.NavigateToDJSets();

        // Act
        await helpers.CreateDJSet(testSet.Name);
        
        // Assert
        await helpers.ExpectSetInDropdown(testSet.Name);
        await helpers.SelectDJSet(testSet.Name);
        await helpers.ExpectSetSelected(testSet.Name);
    }

    [Fact]
    public async Task User_Can_Create_New_DJ_Set_With_Name_And_Description()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        var testSet = TestSets.All[0];
        
        await helpers.NavigateToDJSets();

        // Act
        await helpers.CreateDJSet(testSet.Name, testSet.Description);
        
        // Assert
        await helpers.ExpectSetInDropdown(testSet.Name);
        await helpers.SelectDJSet(testSet.Name);
        await Expect(page.GetByText(testSet.Description)).ToBeVisibleAsync();
    }

    [Fact]
    public async Task Create_Button_Should_Open_Modal()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        
        await helpers.NavigateToDJSets();

        // Act
        await page.GetByTestId("create-set-button").ClickAsync();
        
        // Assert
        await Expect(page.GetByTestId("set-name-input")).ToBeVisibleAsync();
        await Expect(page.GetByTestId("set-description-input")).ToBeVisibleAsync();
        await Expect(page.GetByTestId("save-set-button")).ToBeVisibleAsync();
    }

    [Fact]
    public async Task Save_Button_Should_Be_Disabled_With_Empty_Name()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        
        await helpers.NavigateToDJSets();

        // Act & Assert
        await page.GetByTestId("create-set-button").ClickAsync();
        
        await Expect(page.GetByTestId("save-set-button")).ToBeDisabledAsync();
        
        await page.GetByTestId("set-name-input").FillAsync("Test");
        await Expect(page.GetByTestId("save-set-button")).ToBeEnabledAsync();
        
        await page.GetByTestId("set-name-input").ClearAsync();
        await Expect(page.GetByTestId("save-set-button")).ToBeDisabledAsync();
    }

    [Fact]
    public async Task User_Can_Select_Different_Sets()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        var set1 = TestSets.All[0];
        var set2 = TestSets.All[1];
        
        await helpers.NavigateToDJSets();

        // Act
        await helpers.CreateDJSet(set1.Name, set1.Description);
        await helpers.CreateDJSet(set2.Name, set2.Description);
        
        // Select first set
        await helpers.SelectDJSet(set1.Name);
        await Expect(page.GetByText(set1.Description)).ToBeVisibleAsync();
        
        // Select second set
        await helpers.SelectDJSet(set2.Name);
        
        // Assert
        await Expect(page.GetByText(set2.Description)).ToBeVisibleAsync();
        await Expect(page.GetByText(set1.Description)).Not.ToBeVisibleAsync();
    }

    [Fact]
    public async Task Selecting_Set_Should_Show_Song_Management_Interface()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        var testSet = TestSets.All[0];
        
        await helpers.NavigateToDJSets();

        // Act
        await helpers.CreateDJSet(testSet.Name);
        await helpers.SelectDJSet(testSet.Name);
        
        // Assert
        await Expect(page.GetByText("Songs in Set")).ToBeVisibleAsync();
        await Expect(page.GetByTestId("add-song-main-button")).ToBeVisibleAsync();
    }

    [Fact]
    public async Task User_Can_Edit_Set_Name()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        var originalName = TestSets.All[0].Name;
        var newName = "Updated Test Set";
        
        await helpers.NavigateToDJSets();

        // Act
        await helpers.CreateDJSet(originalName);
        await helpers.SelectDJSet(originalName);
        await helpers.EditDJSet(newName);
        
        // Assert
        await helpers.ExpectSetInDropdown(newName);
        await Expect(page.GetByText(originalName)).Not.ToBeVisibleAsync();
    }

    [Fact]
    public async Task User_Can_Edit_Set_Description()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        var testSet = TestSets.All[0];
        var newDescription = "Updated description";
        
        await helpers.NavigateToDJSets();

        // Act
        await helpers.CreateDJSet(testSet.Name, testSet.Description);
        await helpers.SelectDJSet(testSet.Name);
        await helpers.EditDJSet(testSet.Name, newDescription);
        
        // Assert
        await Expect(page.GetByText(newDescription)).ToBeVisibleAsync();
        await Expect(page.GetByText(testSet.Description)).Not.ToBeVisibleAsync();
    }

    [Fact]
    public async Task Edit_Button_Should_Only_Appear_When_Set_Is_Selected()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        var testSet = TestSets.All[0];
        
        await helpers.NavigateToDJSets();

        // Act & Assert
        await Expect(page.GetByTestId("edit-set-button")).Not.ToBeVisibleAsync();
        
        await helpers.CreateDJSet(testSet.Name);
        await helpers.SelectDJSet(testSet.Name);
        
        await Expect(page.GetByTestId("edit-set-button")).ToBeVisibleAsync();
    }

    [Fact]
    public async Task User_Can_Delete_Sets()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        var setName = TestSets.All[0].Name;
        
        await helpers.NavigateToDJSets();

        // Act
        await helpers.CreateDJSet(setName);
        await helpers.SelectDJSet(setName);
        await helpers.DeleteDJSet();
        
        // Assert
        await Expect(page.GetByText(setName)).Not.ToBeVisibleAsync();
        await Expect(page.GetByTestId("edit-set-button")).Not.ToBeVisibleAsync();
    }

    [Fact]
    public async Task Delete_Button_Should_Only_Appear_When_Set_Is_Selected()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        var testSet = TestSets.All[0];
        
        await helpers.NavigateToDJSets();

        // Act & Assert
        await Expect(page.GetByTestId("delete-set-button")).Not.ToBeVisibleAsync();
        
        await helpers.CreateDJSet(testSet.Name);
        await helpers.SelectDJSet(testSet.Name);
        
        await Expect(page.GetByTestId("delete-set-button")).ToBeVisibleAsync();
    }

    [Fact]
    public async Task Should_Show_Empty_Set_Message_For_New_Sets()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        var testSet = TestSets.All[0];
        
        await helpers.NavigateToDJSets();

        // Act
        await helpers.CreateDJSet(testSet.Name);
        await helpers.SelectDJSet(testSet.Name);
        
        // Assert
        await helpers.ExpectEmptySet();
        await Expect(page.GetByTestId("add-first-song-button")).ToBeVisibleAsync();
    }

    [Fact]
    public async Task Should_Show_Getting_Started_Message_When_No_Sets_Exist()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        
        // Act
        await helpers.NavigateToDJSets();
        
        // Assert
        await Expect(page.GetByText("Create a new DJ set")).ToBeVisibleAsync();
        await Expect(page.GetByText("start building your playlist")).ToBeVisibleAsync();
    }

    [Fact]
    public async Task Should_Prevent_Creating_Set_With_Empty_Name()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        
        await helpers.NavigateToDJSets();

        // Act
        await page.GetByTestId("create-set-button").ClickAsync();
        await page.GetByTestId("set-name-input").FillAsync("");
        
        // Assert
        await Expect(page.GetByTestId("save-set-button")).ToBeDisabledAsync();
    }

    [Fact]
    public async Task Should_Handle_Whitespace_Only_Names()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        
        await helpers.NavigateToDJSets();

        // Act
        await page.GetByTestId("create-set-button").ClickAsync();
        await page.GetByTestId("set-name-input").FillAsync("   ");
        
        // Assert
        await Expect(page.GetByTestId("save-set-button")).ToBeDisabledAsync();
    }

    [Fact]
    public async Task Should_Handle_Very_Long_Names()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        var longName = new string('a', 1000);
        
        await helpers.NavigateToDJSets();

        // Act
        await page.GetByTestId("create-set-button").ClickAsync();
        await page.GetByTestId("set-name-input").FillAsync(longName);
        
        // Assert
        // Should either accept it or show validation error
        await Expect(page.GetByTestId("save-set-button")).ToBeEnabledAsync();
    }

    [Fact]
    public async Task Sets_Should_Persist_Across_Page_Refreshes()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        var setName = TestSets.All[0].Name;
        
        await helpers.NavigateToDJSets();

        // Act
        await helpers.CreateDJSet(setName);
        await helpers.RefreshPage();
        
        // Assert
        await helpers.ExpectSetInDropdown(setName);
    }

    [Fact]
    public async Task Sets_Should_Persist_Across_Browser_Sessions()
    {
        // Arrange
        var setName = TestSets.All[0].Name;
        
        // Create set in first session
        using (var page1 = await CreatePageAsync())
        {
            var helpers1 = new DJSetTestHelpers(page1);
            await helpers1.NavigateToDJSets();
            await helpers1.CreateDJSet(setName);
        }
        
        // Act & Assert - Verify in new session
        using (var page2 = await CreatePageAsync())
        {
            var helpers2 = new DJSetTestHelpers(page2);
            await helpers2.NavigateToDJSets();
            await helpers2.ExpectSetInDropdown(setName);
        }
    }
}