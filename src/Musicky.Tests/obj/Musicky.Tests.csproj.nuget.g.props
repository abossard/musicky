    <PkgGrpc_Tools Condition=" '$(PkgGrpc_Tools)' == '' ">/Users/abossard/.nuget/packages/grpc.tools/2.71.0</PkgGrpc_Tools>
    <PkgMicrosoft_CodeAnalysis_Analyzers Condition=" '$(PkgMicrosoft_CodeAnalysis_Analyzers)' == '' ">/Users/abossard/.nuget/packages/microsoft.codeanalysis.analyzers/3.3.4</PkgMicrosoft_CodeAnalysis_Analyzers>
