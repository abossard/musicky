using Microsoft.Playwright;
using Musicky.Tests.Fixtures;
using Musicky.Tests.Helpers;

namespace Musicky.Tests;

public class SongSearchManagementTests : TestBase
{
    [Fact]
    public async Task User_Can_Open_Search_Popup()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        var testSet = TestSets.All[0];

        await helpers.NavigateToDJSets();
        await helpers.CreateDJSet(testSet.Name);
        await helpers.SelectDJSet(testSet.Name);

        // Act
        await helpers.OpenSearchPopup();

        // Assert
        await Expect(page.GetByTestId("search-popup")).ToBeVisibleAsync();
        await Expect(page.GetByTestId("search-input")).ToBeVisibleAsync();
        await Expect(page.GetByText("Search for songs")).ToBeVisibleAsync();
    }

    [Fact]
    public async Task User_Can_Close_Search_Popup_With_Escape()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        var testSet = TestSets.All[0];

        await helpers.NavigateToDJSets();
        await helpers.CreateDJSet(testSet.Name);
        await helpers.SelectDJSet(testSet.Name);
        await helpers.OpenSearchPopup();

        // Act
        await helpers.CloseSearchPopup();

        // Assert
        await Expect(page.GetByTestId("search-popup")).Not.ToBeVisibleAsync();
    }

    [Fact]
    public async Task User_Can_Search_For_Songs()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        var testSet = TestSets.All[0];

        await helpers.NavigateToDJSets();
        await helpers.CreateDJSet(testSet.Name);
        await helpers.SelectDJSet(testSet.Name);
        await helpers.OpenSearchPopup();

        // Act
        await helpers.SearchForSong(SearchQueries.Valid[0]);

        // Assert
        // Results should appear (depends on test data)
        await page.WaitForTimeoutAsync(1000);
    }

    [Fact]
    public async Task User_Can_Select_Search_Result()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        var testSet = TestSets.All[0];

        await helpers.NavigateToDJSets();
        await helpers.CreateDJSet(testSet.Name);
        await helpers.SelectDJSet(testSet.Name);

        // Act
        await helpers.AddSongToSet(SearchQueries.Valid[0]);

        // Assert
        await Expect(page.GetByTestId("search-popup")).Not.ToBeVisibleAsync();
        // Song should be added to the set
    }

    [Fact]
    public async Task Search_Should_Show_Song_Details()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        var testSet = TestSets.All[0];

        await helpers.NavigateToDJSets();
        await helpers.CreateDJSet(testSet.Name);
        await helpers.SelectDJSet(testSet.Name);
        await helpers.OpenSearchPopup();

        // Act
        await helpers.SearchForSong(SearchQueries.Valid[0]);
        await page.WaitForTimeoutAsync(1000);

        // Assert - Search results should show song metadata
        var hasResults = await page.GetByTestId("search-result-item").CountAsync() > 0;
        if (hasResults)
        {
            await Expect(page.GetByTestId("song-title")).ToBeVisibleAsync();
            await Expect(page.GetByTestId("song-artist")).ToBeVisibleAsync();
        }
    }

    [Fact]
    public async Task Search_Should_Show_No_Results_Message()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        var testSet = TestSets.All[0];

        await helpers.NavigateToDJSets();
        await helpers.CreateDJSet(testSet.Name);
        await helpers.SelectDJSet(testSet.Name);
        await helpers.OpenSearchPopup();

        // Act
        await helpers.SearchForSong(SearchQueries.NoResults);
        await page.WaitForTimeoutAsync(1000);

        // Assert
        await helpers.ExpectNoSearchResults();
    }

    [Fact]
    public async Task Search_Should_Be_Case_Insensitive()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        var testSet = TestSets.All[0];

        await helpers.NavigateToDJSets();
        await helpers.CreateDJSet(testSet.Name);
        await helpers.SelectDJSet(testSet.Name);
        await helpers.OpenSearchPopup();

        // Act
        await helpers.SearchForSong("TEST SONG");
        await page.WaitForTimeoutAsync(1000);

        // Same as lowercase search
        await helpers.SearchForSong("test song");
        await page.WaitForTimeoutAsync(1000);

        // Assert - Both searches should return same results
        // This is behavior validation rather than specific assertion
    }

    [Fact]
    public async Task Search_Should_Handle_Special_Characters()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        var testSet = TestSets.All[0];

        await helpers.NavigateToDJSets();
        await helpers.CreateDJSet(testSet.Name);
        await helpers.SelectDJSet(testSet.Name);
        await helpers.OpenSearchPopup();

        // Act - Search with special characters
        await helpers.SearchForSong("@#$%^&*()");
        await page.WaitForTimeoutAsync(1000);

        // Assert - Should not crash and should show appropriate message
        var hasError = await page.GetByText("Search error").IsVisibleAsync();
        var hasNoResults = await page.GetByText("No songs found").IsVisibleAsync();
        
        (!hasError).Should().BeTrue("Search should not show error with special characters");
    }

    [Fact]
    public async Task Search_Should_Debounce_Input()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        var testSet = TestSets.All[0];

        await helpers.NavigateToDJSets();
        await helpers.CreateDJSet(testSet.Name);
        await helpers.SelectDJSet(testSet.Name);
        await helpers.OpenSearchPopup();

        // Act - Type quickly without waiting
        await page.GetByTestId("search-input").TypeAsync("test song", new() { Delay = 50 });

        // Assert - Should wait for debounce before searching
        await page.WaitForTimeoutAsync(600); // Wait longer than debounce
    }

    [Fact]
    public async Task Multiple_Search_Results_Should_Be_Selectable()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        var testSet = TestSets.All[0];

        await helpers.NavigateToDJSets();
        await helpers.CreateDJSet(testSet.Name);
        await helpers.SelectDJSet(testSet.Name);
        await helpers.OpenSearchPopup();

        // Act
        await helpers.SearchForSong("test"); // Broad search to get multiple results
        await page.WaitForTimeoutAsync(1000);

        var resultCount = await page.GetByTestId("search-result-item").CountAsync();
        
        // Assert - Should be able to click on any result
        if (resultCount > 1)
        {
            // Select second result
            await helpers.SelectSearchResult(1);
            await Expect(page.GetByTestId("search-popup")).Not.ToBeVisibleAsync();
        }
    }

    [Fact]
    public async Task Search_Popup_Should_Focus_Input_On_Open()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        var testSet = TestSets.All[0];

        await helpers.NavigateToDJSets();
        await helpers.CreateDJSet(testSet.Name);
        await helpers.SelectDJSet(testSet.Name);

        // Act
        await helpers.OpenSearchPopup();

        // Assert
        await Expect(page.GetByTestId("search-input")).ToBeFocusedAsync();
    }

    [Fact]
    public async Task Search_Should_Handle_Empty_Input()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        var testSet = TestSets.All[0];

        await helpers.NavigateToDJSets();
        await helpers.CreateDJSet(testSet.Name);
        await helpers.SelectDJSet(testSet.Name);
        await helpers.OpenSearchPopup();

        // Act
        await page.GetByTestId("search-input").FillAsync("");
        await page.WaitForTimeoutAsync(1000);

        // Assert - Should show initial state or instruction message
        await Expect(page.GetByText("Enter a search term")).ToBeVisibleAsync();
    }

    [Theory]
    [InlineData("a")]
    [InlineData("ab")]
    [InlineData("abc")]
    public async Task Search_Should_Handle_Short_Queries(string query)
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        var testSet = TestSets.All[0];

        await helpers.NavigateToDJSets();
        await helpers.CreateDJSet(testSet.Name);
        await helpers.SelectDJSet(testSet.Name);
        await helpers.OpenSearchPopup();

        // Act
        await helpers.SearchForSong(query);
        await page.WaitForTimeoutAsync(1000);

        // Assert - Should either show results or appropriate message
        var hasResults = await page.GetByTestId("search-result-item").CountAsync() > 0;
        var hasMessage = await page.GetByText("Enter at least 3 characters").IsVisibleAsync() ||
                        await page.GetByText("No songs found").IsVisibleAsync();

        (hasResults || hasMessage).Should().BeTrue();
    }
}