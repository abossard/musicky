using Microsoft.Playwright;
using Musicky.Tests.Fixtures;
using Musicky.Tests.Helpers;

namespace Musicky.Tests;

public class EndToEndWorkflowTests : TestBase
{
    [Fact]
    public async Task Complete_DJ_Set_Creation_And_Management_Workflow()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        var testSet = TestSets.All[0];

        // Act & Assert - Complete workflow
        
        // 1. Navigate to DJ Sets page
        await helpers.NavigateToDJSets();
        await Expect(page.GetByText("DJ Set Management")).ToBeVisibleAsync();

        // 2. Create a new DJ set
        await helpers.CreateDJSet(testSet.Name, testSet.Description);
        await helpers.ExpectSetInDropdown(testSet.Name);

        // 3. Select the set and verify empty state
        await helpers.SelectDJSet(testSet.Name);
        await helpers.ExpectEmptySet();
        await Expect(page.GetByTestId("add-first-song-button")).ToBeVisibleAsync();

        // 4. Add first song to the set
        await helpers.AddSongToSet(SearchQueries.Valid[0]);
        await helpers.ExpectSongCount(1);

        // 5. Add more songs
        await helpers.AddSongToSet(SearchQueries.Valid[1]);
        await helpers.ExpectSongCount(2);

        // 6. Remove a song
        await helpers.RemoveSongFromSet(0);
        await helpers.ExpectSongCount(1);

        // 7. Edit the set details
        var updatedName = "Updated " + testSet.Name;
        var updatedDescription = "Updated " + testSet.Description;
        await helpers.EditDJSet(updatedName, updatedDescription);
        
        // 8. Verify changes persisted
        await Expect(page.GetByText(updatedDescription)).ToBeVisibleAsync();
        await helpers.ExpectSetInDropdown(updatedName);

        // 9. Verify persistence across page refresh
        await helpers.RefreshPage();
        await helpers.ExpectSetInDropdown(updatedName);
        await helpers.ExpectSongCount(1);
    }

    [Fact]
    public async Task Complete_MP3_Library_To_DJ_Set_Integration_Workflow()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        var testSet = TestSets.All[0];

        // Act & Assert - Integration workflow

        // 1. Create DJ set first
        await helpers.NavigateToDJSets();
        await helpers.CreateDJSet(testSet.Name);

        // 2. Navigate to MP3 Library
        await helpers.NavigateToMP3Library();
        await Expect(page.GetByText("MP3 Library")).ToBeVisibleAsync();

        // 3. Enable DJ set mode
        await helpers.EnableDJSetMode();
        await Expect(page.GetByTestId("active-set-selector")).ToBeVisibleAsync();

        // 4. Select active set
        await helpers.SelectActiveSet(testSet.Name);

        // 5. Search for music
        await page.GetByRole(AriaRole.Textbox, new() { Name = "Search" }).FillAsync("test");
        await page.WaitForTimeoutAsync(1000);

        // 6. Select multiple songs
        await helpers.SelectSongsInLibrary(2);
        await Expect(page.GetByText("2 selected")).ToBeVisibleAsync();

        // 7. Add selected songs to set
        await helpers.AddSelectedSongsToSet();
        await Expect(page.GetByText("Songs added to set")).ToBeVisibleAsync();

        // 8. Navigate back to DJ Sets and verify songs were added
        await helpers.NavigateToDJSets();
        await helpers.SelectDJSet(testSet.Name);
        await helpers.ExpectSongCount(2);

        // 9. Clear selection and verify
        await helpers.NavigateToMP3Library();
        await helpers.ClearSelection();
        await Expect(page.GetByText("2 selected")).Not.ToBeVisibleAsync();
    }

    [Fact]
    public async Task Multiple_Sets_Management_Workflow()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        var set1 = TestSets.All[0];
        var set2 = TestSets.All[1];
        var set3 = TestSets.All[2];

        // Act & Assert - Multiple sets workflow

        // 1. Create multiple sets
        await helpers.NavigateToDJSets();
        await helpers.CreateDJSet(set1.Name, set1.Description);
        await helpers.CreateDJSet(set2.Name, set2.Description);
        await helpers.CreateDJSet(set3.Name, set3.Description);

        // 2. Add songs to first set
        await helpers.SelectDJSet(set1.Name);
        await helpers.AddSongToSet(SearchQueries.Valid[0]);
        await helpers.AddSongToSet(SearchQueries.Valid[1]);
        await helpers.ExpectSongCount(2);

        // 3. Add songs to second set
        await helpers.SelectDJSet(set2.Name);
        await helpers.AddSongToSet(SearchQueries.Valid[1]);
        await helpers.ExpectSongCount(1);

        // 4. Keep third set empty and verify
        await helpers.SelectDJSet(set3.Name);
        await helpers.ExpectEmptySet();

        // 5. Switch between sets and verify content
        await helpers.SelectDJSet(set1.Name);
        await helpers.ExpectSongCount(2);
        await Expect(page.GetByText(set1.Description)).ToBeVisibleAsync();

        await helpers.SelectDJSet(set2.Name);
        await helpers.ExpectSongCount(1);
        await Expect(page.GetByText(set2.Description)).ToBeVisibleAsync();

        // 6. Delete one set and verify others remain
        await helpers.DeleteDJSet();
        await Expect(page.GetByText(set2.Name)).Not.ToBeVisibleAsync();

        // 7. Verify remaining sets still work
        await helpers.SelectDJSet(set1.Name);
        await helpers.ExpectSongCount(2);

        await helpers.SelectDJSet(set3.Name);
        await helpers.ExpectEmptySet();
    }

    [Fact]
    public async Task Search_And_Add_Songs_With_Different_Queries_Workflow()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        var testSet = TestSets.All[0];

        await helpers.NavigateToDJSets();
        await helpers.CreateDJSet(testSet.Name);
        await helpers.SelectDJSet(testSet.Name);

        // Act & Assert - Search workflow with different queries

        // 1. Test each valid search query
        foreach (var query in SearchQueries.Valid.Take(3)) // Limit to first 3 for test performance
        {
            await helpers.OpenSearchPopup();
            await helpers.SearchForSong(query);
            await page.WaitForTimeoutAsync(1000);

            // If results found, add first one
            var resultCount = await page.GetByTestId("search-result-item").CountAsync();
            if (resultCount > 0)
            {
                await helpers.SelectSearchResult(0);
            }
            else
            {
                await helpers.CloseSearchPopup();
            }
        }

        // 2. Test invalid search
        await helpers.OpenSearchPopup();
        await helpers.SearchForSong(SearchQueries.NoResults);
        await page.WaitForTimeoutAsync(1000);
        await helpers.ExpectNoSearchResults();
        await helpers.CloseSearchPopup();

        // 3. Verify songs were added from valid searches
        var songCount = await page.GetByTestId("song-item").CountAsync();
        songCount.Should().BeGreaterThan(0, "At least one song should have been added from valid searches");
    }

    [Fact]
    public async Task Song_Position_Management_Workflow()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        var testSet = TestSets.All[0];

        await helpers.NavigateToDJSets();
        await helpers.CreateDJSet(testSet.Name);
        await helpers.SelectDJSet(testSet.Name);

        // Act & Assert - Position management workflow

        // 1. Add multiple songs
        await helpers.AddSongToSet(SearchQueries.Valid[0]);
        await helpers.AddSongToSet(SearchQueries.Valid[1]);
        await helpers.AddSongToSet(SearchQueries.Valid[2]);
        await helpers.ExpectSongCount(3);

        // 2. Add song after specific position
        await helpers.AddSongAfterPosition(1, SearchQueries.Valid[0]);
        await helpers.ExpectSongCount(4);

        // 3. Remove song from middle
        await helpers.RemoveSongFromSet(2);
        await helpers.ExpectSongCount(3);

        // 4. Verify order is maintained
        var songItems = page.GetByTestId("song-item");
        var count = await songItems.CountAsync();
        count.Should().Be(3);
    }

    [Fact]
    public async Task Data_Persistence_Across_Navigation_Workflow()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        var testSet = TestSets.All[0];

        // Act & Assert - Data persistence workflow

        // 1. Create set with songs
        await helpers.NavigateToDJSets();
        await helpers.CreateDJSet(testSet.Name, testSet.Description);
        await helpers.SelectDJSet(testSet.Name);
        await helpers.AddSongToSet(SearchQueries.Valid[0]);
        await helpers.AddSongToSet(SearchQueries.Valid[1]);

        // 2. Navigate to MP3 Library and back
        await helpers.NavigateToMP3Library();
        await helpers.NavigateToDJSets();

        // 3. Verify data persisted
        await helpers.ExpectSetInDropdown(testSet.Name);
        await helpers.SelectDJSet(testSet.Name);
        await helpers.ExpectSongCount(2);
        await Expect(page.GetByText(testSet.Description)).ToBeVisibleAsync();

        // 4. Navigate to home and back
        await page.GotoAsync("/");
        await Expect(page.GetByText("Welcome to Musicky")).ToBeVisibleAsync();
        
        await helpers.NavigateToDJSets();
        await helpers.ExpectSetInDropdown(testSet.Name);
        await helpers.SelectDJSet(testSet.Name);
        await helpers.ExpectSongCount(2);

        // 5. Refresh page and verify
        await helpers.RefreshPage();
        await helpers.ExpectSetInDropdown(testSet.Name);
        await helpers.SelectDJSet(testSet.Name);
        await helpers.ExpectSongCount(2);
    }

    [Fact]
    public async Task Error_Recovery_And_Validation_Workflow()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);

        await helpers.NavigateToDJSets();

        // Act & Assert - Error recovery workflow

        // 1. Test invalid inputs for set creation
        foreach (var invalidInput in InvalidInputs.All.Take(3)) // Test first 3 for performance
        {
            await page.GetByTestId("create-set-button").ClickAsync();
            await page.GetByTestId("set-name-input").FillAsync(invalidInput);

            if (string.IsNullOrWhiteSpace(invalidInput))
            {
                await Expect(page.GetByTestId("save-set-button")).ToBeDisabledAsync();
            }

            // Cancel the modal
            await page.Keyboard.PressAsync("Escape");
            await Expect(page.GetByTestId("set-name-input")).Not.ToBeVisibleAsync();
        }

        // 2. Create valid set and test search error recovery
        await helpers.CreateDJSet("Valid Test Set");
        await helpers.SelectDJSet("Valid Test Set");

        // 3. Test search with various inputs
        await helpers.OpenSearchPopup();
        
        // Test empty search
        await helpers.SearchForSong("");
        await page.WaitForTimeoutAsync(500);
        
        // Test special characters
        await helpers.SearchForSong("<script>alert('test')</script>");
        await page.WaitForTimeoutAsync(500);
        
        // Test very long search
        await helpers.SearchForSong(new string('a', 1000));
        await page.WaitForTimeoutAsync(500);

        // Should not crash or show errors
        await Expect(page.GetByText("Application error")).Not.ToBeVisibleAsync();
        await helpers.CloseSearchPopup();

        // 4. Verify application is still functional
        await helpers.ExpectEmptySet();
        await Expect(page.GetByTestId("add-first-song-button")).ToBeVisibleAsync();
    }
}