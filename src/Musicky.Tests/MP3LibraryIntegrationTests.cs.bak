using Microsoft.Playwright;
using Musicky.Tests.Fixtures;
using Musicky.Tests.Helpers;

namespace Musicky.Tests;

public class MP3LibraryIntegrationTests : TestBase
{
    [Fact]
    public async Task MP3_Library_Page_Should_Be_Accessible()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);

        // Act
        await helpers.NavigateToMP3Library();

        // Assert
        await Expect(page.GetByText("MP3 Library")).ToBeVisibleAsync();
        await Expect(page.GetByRole(AriaRole.Textbox, new() { Name = "Search" })).ToBeVisibleAsync();
    }

    [Fact]
    public async Task User_Can_Search_For_Music_Files()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);

        await helpers.NavigateToMP3Library();

        // Act
        await page.GetByRole(AriaRole.Textbox, new() { Name = "Search" }).FillAsync("test");

        // Assert
        // Results should be displayed (depends on test data setup)
        await page.WaitForTimeoutAsync(1000); // Allow search to complete
    }

    [Fact]
    public async Task User_Can_Enable_DJ_Set_Mode()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);

        await helpers.NavigateToMP3Library();

        // Act
        await helpers.EnableDJSetMode();

        // Assert
        await Expect(page.GetByTestId("active-set-selector")).ToBeVisibleAsync();
        await Expect(page.GetByText("DJ Set Mode")).ToBeVisibleAsync();
    }

    [Fact]
    public async Task User_Can_Disable_DJ_Set_Mode()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);

        await helpers.NavigateToMP3Library();
        await helpers.EnableDJSetMode();

        // Act
        await helpers.DisableDJSetMode();

        // Assert
        await Expect(page.GetByTestId("active-set-selector")).Not.ToBeVisibleAsync();
    }

    [Fact]
    public async Task User_Can_Select_Active_Set_In_DJ_Mode()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        var testSet = TestSets.All[0];

        // Create a set first
        await helpers.NavigateToDJSets();
        await helpers.CreateDJSet(testSet.Name);

        // Go to MP3 library
        await helpers.NavigateToMP3Library();
        await helpers.EnableDJSetMode();

        // Act
        await helpers.SelectActiveSet(testSet.Name);

        // Assert
        await Expect(page.GetByTestId("active-set-selector")).ToHaveValueAsync(testSet.Name);
    }

    [Fact]
    public async Task User_Can_Select_Multiple_Songs()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);

        await helpers.NavigateToMP3Library();
        await helpers.EnableDJSetMode();

        // Act
        await helpers.SelectSongsInLibrary(3);

        // Assert
        await Expect(page.GetByText("3 selected")).ToBeVisibleAsync();
        await Expect(page.GetByTestId("add-to-set-button")).ToBeVisibleAsync();
    }

    [Fact]
    public async Task User_Can_Add_Selected_Songs_To_Set()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);
        var testSet = TestSets.All[0];

        // Create a set first
        await helpers.NavigateToDJSets();
        await helpers.CreateDJSet(testSet.Name);

        // Go to MP3 library and add songs
        await helpers.NavigateToMP3Library();
        await helpers.EnableDJSetMode();
        await helpers.SelectActiveSet(testSet.Name);
        await helpers.SelectSongsInLibrary(2);

        // Act
        await helpers.AddSelectedSongsToSet();

        // Assert
        await Expect(page.GetByText("Songs added to set")).ToBeVisibleAsync();
    }

    [Fact]
    public async Task User_Can_Clear_Selection()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);

        await helpers.NavigateToMP3Library();
        await helpers.EnableDJSetMode();
        await helpers.SelectSongsInLibrary(3);

        // Act
        await helpers.ClearSelection();

        // Assert
        await Expect(page.GetByText("3 selected")).Not.ToBeVisibleAsync();
        await Expect(page.GetByTestId("add-to-set-button")).Not.ToBeVisibleAsync();
    }

    [Fact]
    public async Task Selection_Should_Persist_During_Search()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);

        await helpers.NavigateToMP3Library();
        await helpers.SelectSongsInLibrary(2);

        // Act
        await page.GetByRole(AriaRole.Textbox, new() { Name = "Search" }).FillAsync("test");
        await page.WaitForTimeoutAsync(500);

        // Assert
        await Expect(page.GetByText("2 selected")).ToBeVisibleAsync();
    }

    [Fact]
    public async Task Should_Show_Empty_Library_Message_When_No_Songs()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);

        // Act
        await helpers.NavigateToMP3Library();

        // Assert
        await Expect(page.GetByText("No music files found")).ToBeVisibleAsync();
        await Expect(page.GetByText("Add some MP3 files")).ToBeVisibleAsync();
    }

    [Fact]
    public async Task Should_Show_No_Results_Message_For_Invalid_Search()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);

        await helpers.NavigateToMP3Library();

        // Act
        await page.GetByRole(AriaRole.Textbox, new() { Name = "Search" }).FillAsync(SearchQueries.NoResults);
        await page.WaitForTimeoutAsync(1000);

        // Assert
        await Expect(page.GetByText("No songs found")).ToBeVisibleAsync();
    }

    [Fact]
    public async Task Should_Display_Song_Metadata()
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);

        await helpers.NavigateToMP3Library();

        // Act
        await page.GetByRole(AriaRole.Textbox, new() { Name = "Search" }).FillAsync("test");
        await page.WaitForTimeoutAsync(1000);

        // Assert - Song metadata columns should be visible
        await Expect(page.GetByText("Title")).ToBeVisibleAsync();
        await Expect(page.GetByText("Artist")).ToBeVisibleAsync();
        await Expect(page.GetByText("Album")).ToBeVisibleAsync();
        await Expect(page.GetByText("Duration")).ToBeVisibleAsync();
    }

    [Theory]
    [InlineData("Test Song")]
    [InlineData("Test Artist")]
    [InlineData("Album")]
    public async Task Search_Should_Work_With_Different_Queries(string query)
    {
        // Arrange
        using var page = await CreatePageAsync();
        var helpers = new DJSetTestHelpers(page);

        await helpers.NavigateToMP3Library();

        // Act
        await page.GetByRole(AriaRole.Textbox, new() { Name = "Search" }).FillAsync(query);
        await page.WaitForTimeoutAsync(1000);

        // Assert - Should either show results or no results message
        var hasResults = await page.GetByTestId("song-result").CountAsync() > 0;
        var hasNoResults = await page.GetByText("No songs found").IsVisibleAsync();

        (hasResults || hasNoResults).Should().BeTrue();
    }
}