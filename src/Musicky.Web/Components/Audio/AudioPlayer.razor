@using Musicky.Web.Services

<div style="background: #001529; padding: 16px; border-top: 1px solid #303030; color: white;">
    <div style="display: flex; align-items: center; justify-content: space-between;">
        <div style="flex: 1;">
            @if (!string.IsNullOrEmpty(_state.CurrentTrack))
            {
                <div>
                    <strong>@GetTrackTitle()</strong>
                </div>
                <div style="color: #8c8c8c; font-size: 12px;">
                    @GetTrackArtist()
                </div>
            }
            else
            {
                <span style="color: #8c8c8c;">No track loaded</span>
            }
        </div>
        
        <div style="flex: 2; text-align: center;">
            <button 
                @onclick="TogglePlayPause"
                disabled="@(!_state.IsLoaded)"
                style="background: none; border: none; color: white; font-size: 24px; cursor: pointer;">
                @(_state.IsPlaying ? "⏸️" : "▶️")
            </button>
            
            <div style="margin-top: 8px; display: flex; align-items: center; gap: 8px;">
                <span style="color: #8c8c8c; font-size: 12px;">
                    @FormatTime(_state.CurrentTime)
                </span>
                <input 
                    type="range" 
                    min="0" 
                    max="@_state.Duration" 
                    step="1"
                    value="@_state.CurrentTime"
                    @oninput="OnSeek"
                    disabled="@(!_state.IsLoaded)"
                    style="flex: 1;" />
                <span style="color: #8c8c8c; font-size: 12px;">
                    @FormatTime(_state.Duration)
                </span>
            </div>
        </div>
        
        <div style="flex: 1; text-align: right; display: flex; align-items: center; justify-content: flex-end; gap: 8px;">
            <span>🔊</span>
            <input 
                type="range" 
                min="0" 
                max="100" 
                step="1"
                value="@(_state.Volume * 100)"
                @oninput="OnVolumeChange"
                style="width: 80px;" />
        </div>
    </div>
</div>

@code {
    [Inject] public IAudioPlayerService AudioPlayerService { get; set; } = default!;
    
    private AudioPlayerState _state = new();

    private bool _isInitialized = false;

    protected override void OnInitialized()
    {
        AudioPlayerService.StateChanged += OnStateChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_isInitialized)
        {
            await AudioPlayerService.InitializeAsync();
            _state = await AudioPlayerService.GetStateAsync();
            _isInitialized = true;
            StateHasChanged();
        }
    }

    private void OnStateChanged(object? sender, AudioPlayerEventArgs e)
    {
        _state = e.State;
        InvokeAsync(StateHasChanged);
    }

    private async Task TogglePlayPause()
    {
        if (_state.IsPlaying)
        {
            await AudioPlayerService.PauseAsync();
        }
        else
        {
            await AudioPlayerService.PlayAsync();
        }
    }

    private async Task OnSeek(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), out double position))
        {
            await AudioPlayerService.SeekAsync(position);
        }
    }

    private async Task OnVolumeChange(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), out double volume))
        {
            await AudioPlayerService.SetVolumeAsync(volume / 100.0);
        }
    }

    private string GetTrackTitle()
    {
        if (!string.IsNullOrEmpty(_state.CurrentTrack))
        {
            return Path.GetFileNameWithoutExtension(_state.CurrentTrack);
        }
        return "Unknown";
    }

    private string GetTrackArtist()
    {
        return "Local File";
    }

    private string FormatTime(double seconds)
    {
        if (double.IsNaN(seconds) || double.IsInfinity(seconds))
            return "0:00";
            
        var time = TimeSpan.FromSeconds(seconds);
        return time.ToString(@"m\:ss");
    }
}