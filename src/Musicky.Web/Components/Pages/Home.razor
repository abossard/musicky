@page "/"

<PageTitle>Musicky - Home</PageTitle>

<div style="text-align: center; padding: 50px 0;">
    <h1>🎵 Welcome to Musicky</h1>
    
    <p style="font-size: 18px; margin: 32px 0;">
        Your personal music library management and DJ set creation platform
    </p>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 24px; margin-top: 48px;">
        <div style="border: 1px solid #ddd; border-radius: 8px; padding: 32px; cursor: pointer;" @onclick="NavigateToLibrary">
            <div style="font-size: 48px; margin-bottom: 16px;">💿</div>
            <h4>MP3 Library</h4>
            <p style="color: #666;">Search and manage your music collection</p>
        </div>
        
        <div style="border: 1px solid #ddd; border-radius: 8px; padding: 32px; cursor: pointer;" @onclick="NavigateToDjSets">
            <div style="font-size: 48px; margin-bottom: 16px;">🎵</div>
            <h4>DJ Sets</h4>
            <p style="color: #666;">Create and organize your playlists</p>
        </div>
        
        <div style="border: 1px solid #ddd; border-radius: 8px; padding: 32px; cursor: pointer;" @onclick="NavigateToFileBrowser">
            <div style="font-size: 48px; margin-bottom: 16px;">📁</div>
            <h4>File Browser</h4>
            <p style="color: #666;">Browse your local music files</p>
        </div>
        
        <div style="border: 1px solid #ddd; border-radius: 8px; padding: 32px; cursor: pointer;" @onclick="NavigateToAudioPlayer">
            <div style="font-size: 48px; margin-bottom: 16px;">▶️</div>
            <h4>Audio Player</h4>
            <p style="color: #666;">Play and control your music</p>
        </div>
    </div>
</div>

@code {
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private void NavigateToLibrary() => Navigation.NavigateTo("/mp3-library");
    private void NavigateToDjSets() => Navigation.NavigateTo("/dj-sets");
    private void NavigateToFileBrowser() => Navigation.NavigateTo("/file-browser");
    private void NavigateToAudioPlayer() => Navigation.NavigateTo("/audio-player");
}
